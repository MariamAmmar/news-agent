# Copy this file to .env and fill in your values.
# .env is listed in .gitignore — never commit it.

# ── SMTP (required to send email) ────────────────────────────────────────────
# Gmail: enable 2-FA, then generate an App Password at
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# Sender display address (defaults to SMTP_USER if omitted)
EMAIL_FROM=AI News Briefing <you@gmail.com>

# Per-newsletter recipient lists (comma-separated).
# EMAIL_TO_GENERAL goes to the general AI briefing.
# EMAIL_TO_HEALTHCARE goes to the healthcare AI briefing.
# If either is omitted, EMAIL_TO is used as a fallback for that newsletter.
EMAIL_TO_GENERAL=you@gmail.com,colleague@example.com
EMAIL_TO_HEALTHCARE=clinician@example.com

# Fallback recipient(s) when no topic-specific list is set
EMAIL_TO=you@gmail.com

# ── Anthropic API (optional – enables AI-generated Key Takeaway) ─────────────
# Get your key at https://console.anthropic.com/
# If omitted, the Key Takeaway falls back to a heuristic summary.
# ANTHROPIC_API_KEY=sk-ant-...

# ── Optional overrides ────────────────────────────────────────────────────────
# DB_PATH=ai_news.db          # SQLite file path
# NEWSLETTER_DAYS_BACK=2      # how many days of articles to consider
# NEWSLETTER_MAX_STORIES=5    # total stories: 1 hero + up to 4 supporting
# SKIP_EMAIL=1                # generate newsletter but don't send it
